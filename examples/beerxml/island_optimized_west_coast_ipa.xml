        <TIME>5</TIME>
        <FORM>Pellet</FORM>
        <NOTES>Grapefruit, floral. Late-boil punch.</NOTES>
      </HOP>
      <HOP>
        <NAME>Centennial</NAME>
        <VERSION>1</VERSION>
        <ALPHA>10.0</ALPHA>
        <AMOUNT>0.142</AMOUNT>
        <USE>Dry Hop</USE>
        <TIME>4</TIME>
        <FORM>Pellet</FORM>
        <NOTES>First dry-hop charge at day 3 of primary.</NOTES>
      </HOP>
      <HOP>
        <NAME>Citra</NAME>
        <VERSION>1</VERSION>
        <ALPHA>12.0</ALPHA>
