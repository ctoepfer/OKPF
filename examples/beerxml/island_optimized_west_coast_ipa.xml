        <NOTES>Clean, neutral fermentation character. Ideal for showcasing hop aroma.</NOTES>
      </YEAST>
    </YEASTS>

    <MISCS>
      <MISC>
        <NAME>Gypsum (Calcium Sulfate)</NAME>
        <VERSION>1</VERSION>
        <TYPE>Water Agent</TYPE>
        <USE>Mash</USE>
        <TIME>0</TIME>
        <AMOUNT>0.007</AMOUNT>
        <AMOUNT_IS_WEIGHT>TRUE</AMOUNT_IS_WEIGHT>
        <NOTES>Raises sulfate to ~120 ppm for hop-forward character.</NOTES>
      </MISC>
      <MISC>
        <NAME>Lactic Acid (88%)</NAME>
        <VERSION>1</VERSION>
        <TYPE>Water Agent</TYPE>
        <USE>Mash</USE>
        <TIME>0</TIME>
        <AMOUNT>0.003</AMOUNT>
        <AMOUNT_IS_WEIGHT>FALSE</AMOUNT_IS_WEIGHT>
        <NOTES>Brings mash pH to 5.3–5.4 from island water baseline ~7.5.</NOTES>
      </MISC>
      <MISC>
        <NAME>Irish Moss</NAME>
        <VERSION>1</VERSION>
