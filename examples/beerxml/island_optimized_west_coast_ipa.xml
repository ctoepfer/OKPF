        <COLOR>2.0</COLOR>
        <ORIGIN>US</ORIGIN>
        <NOTES>Base malt. Crisp, neutral backbone.</NOTES>
      </FERMENTABLE>
      <FERMENTABLE>
        <NAME>White Wheat Malt</NAME>
        <VERSION>1</VERSION>
        <TYPE>Grain</TYPE>
        <AMOUNT>1.134</AMOUNT>
        <YIELD>83.0</YIELD>
        <COLOR>2.0</COLOR>
