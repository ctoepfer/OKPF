        <USE>Boil</USE>
        <TIME>15</TIME>
        <AMOUNT>0.005</AMOUNT>
        <AMOUNT_IS_WEIGHT>TRUE</AMOUNT_IS_WEIGHT>
        <NOTES>Kettle fining for improved clarity.</NOTES>
      </MISC>
    </MISCS>

    <WATERS>
      <WATER>
        <NAME>Island Source Water (adjusted)</NAME>
        <VERSION>1</VERSION>
        <AMOUNT>75.708</AMOUNT>
        <CALCIUM>120.0</CALCIUM>
        <BICARBONATE>30.0</BICARBONATE>
        <SULFATE>125.0</SULFATE>
        <CHLORIDE>55.0</CHLORIDE>
        <SODIUM>10.0</SODIUM>
        <MAGNESIUM>5.0</MAGNESIUM>
        <PH>5.35</PH>
        <NOTES>Adjusted from soft island well water. Sulfate-to-chloride ratio 2.3:1 for dry, hoppy character.</NOTES>
      </WATER>
    </WATERS>

    <MASH>
      <NAME>Single Infusion Mash</NAME>
      <VERSION>1</VERSION>
      <GRAIN_TEMP>20.0</GRAIN_TEMP>
      <SPARGE_TEMP>76.0</SPARGE_TEMP>
      <PH>5.35</PH>
