          <STEP_TEMP>76.0</STEP_TEMP>
          <STEP_TIME>10</STEP_TIME>
          <RAMP_TIME>5</RAMP_TIME>
        </MASH_STEP>
      </MASH_STEPS>
    </MASH>

  </RECIPE>
</RECIPES>
