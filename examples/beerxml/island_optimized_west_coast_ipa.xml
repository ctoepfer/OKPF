      </FERMENTABLE>
    </FERMENTABLES>

    <HOPS>
      <HOP>
        <NAME>Magnum</NAME>
        <VERSION>1</VERSION>
        <ALPHA>14.0</ALPHA>
        <AMOUNT>0.085</AMOUNT>
        <USE>Boil</USE>
        <TIME>60</TIME>
        <FORM>Pellet</FORM>
        <NOTES>Clean bittering addition. No aroma contribution at 60 min.</NOTES>
      </HOP>
      <HOP>
        <NAME>Centennial</NAME>
        <VERSION>1</VERSION>
        <ALPHA>10.0</ALPHA>
        <AMOUNT>0.057</AMOUNT>
        <USE>Boil</USE>
        <TIME>15</TIME>
        <FORM>Pellet</FORM>
        <NOTES>Floral, citrus. Builds mid-boil aroma.</NOTES>
      </HOP>
      <HOP>
        <NAME>Cascade</NAME>
        <VERSION>1</VERSION>
        <ALPHA>6.5</ALPHA>
        <AMOUNT>0.085</AMOUNT>
