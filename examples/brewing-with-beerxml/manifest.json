{
  "$schema": "https://okpf.org/schema/v0.1.0/manifest.schema.json",
  "okpf_version": "0.1",
  "package_id": "brewing-with-beerxml-example",
  "name": "Brewing Knowledge Pack with BeerXML",
  "version": "1.0.0",
  "domain": "brewing",
  "profiles": ["okpf-core", "okpf-fermentation"],
  "records": [
    {
      "path": "records/records.jsonl",
      "format": "jsonl",
      "record_count": 2
    }
  ],
  "sources": [
    {
      "path": "sources/sample-recipe.xml",
      "format": "beerxml",
      "role": "domain_artifact"
    },
    {
      "path": "docs/recipe-explanation.md",
      "format": "markdown",
      "role": "explanation"
    }
  ],
  "license": {
    "type": "example",
    "details": "For OKPF documentation and testing."
  },
  "usage_policy": {
    "allow_rag": true,
    "allow_fine_tuning": false,
    "allow_evaluation": true,
    "allow_commercial_use": true,
    "allow_derivatives": true,
    "allow_commercial_derivatives": true,
    "require_attribution": true,
    "notes": "BeerXML remains the domain artifact; OKPF provides package context."
  },
  "dependencies": [
    {
      "name": "BeerXML",
      "version": "1.0",
      "uri": "https://www.beerxml.com/",
      "optional": true,
      "description": "Domain format used by the sample recipe source artifact."
    }
  ],
  "provenance": {
    "sources": "provenance/sources.json"
  }
}
