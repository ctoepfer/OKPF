      "notes": "Bold citrus and floral flavor; higher alpha than Cascade"
    },
    {
      "name": "Cascade",
      "amount_oz": 0.5,
      "amount_g": 14.17,
      "alpha_acid_pct": 5.5,
      "addition_time_min": 5,
      "addition_type": "aroma",
      "notes": "Late addition for aroma"
    },
    {
      "name": "Cascade",
      "amount_oz": 0.5,
      "amount_g": 14.17,
      "alpha_acid_pct": 5.5,
      "addition_time_min": 0,
      "addition_type": "dry_hop",
      "dry_hop_days": 4,
      "notes": "Added 4–5 days into fermentation; removed before cold crash"
    }
  ],
  "yeast": [
