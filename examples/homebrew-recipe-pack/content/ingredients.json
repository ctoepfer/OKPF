    },
    {
      "name": "Victory Malt",
      "amount_lb": 0.25,
      "amount_kg": 0.11,
      "lovibond": 25,
      "role": "specialty",
      "notes": "Adds toasty, biscuit character; can substitute Biscuit Malt"
    }
  ],
  "hops": [
