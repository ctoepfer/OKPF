{
  "name": "okpf",
  "version": "0.0.1",
  "description": "JavaScript/TypeScript reference implementation for the Open Knowledge Pack Format",
  "keywords": ["okpf", "knowledge", "knowledge-pack", "open-standard"],
  "homepage": "https://github.com/ctoepfer/OKPF",
  "bugs": { "url": "https://github.com/ctoepfer/OKPF/issues" },
  "repository": { "type": "git", "url": "https://github.com/ctoepfer/OKPF.git" },
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/",
