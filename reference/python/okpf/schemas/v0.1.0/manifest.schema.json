{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okpf.org/schema/v0.1.0/manifest.schema.json",
  "title": "OKPF v0.1.0 Manifest",
  "type": "object",
  "required": [
    "okpf_version",
    "name",
    "version",
    "domain",
    "license"
  ],
  "allOf": [
    {
      "anyOf": [
        { "required": ["package_id"] },
        { "required": ["id"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["artifacts"] },
        { "required": ["records"] },
        { "required": ["content"] }
      ]
    }
  ],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "okpf_version": {
      "type": "string",
      "pattern": "^0\\.1(?:\\.0)?$"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Compatibility alias for package_id in older v0.1 examples."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "creators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/party"
      }
    },
    "contributors": {
      "anyOf": [
        { "$ref": "#/$defs/refObject" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/party"
          }
        }
      ]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifactEntry"
      }
    },
    "content": {
      "type": "array",
      "minItems": 1,
      "description": "Compatibility alias for artifacts in older v0.1 examples.",
      "items": {
        "$ref": "#/$defs/artifactEntry"
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileEntry"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileEntry"
      }
    },
    "license": {
      "anyOf": [
        { "$ref": "#/$defs/refObject" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string"
            },
            "details": {
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          }
        }
      ]
    },
    "usage_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "allow_rag": {
          "type": "boolean"
        },
        "allow_fine_tuning": {
          "type": "boolean"
        },
        "allow_evaluation": {
          "type": "boolean"
        },
        "allow_commercial_use": {
          "type": "boolean"
        },
        "allow_derivatives": {
          "type": "boolean"
        },
        "allow_commercial_derivatives": {
          "type": "boolean"
        },
        "require_attribution": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "expert_notes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "rationale": {
          "type": "string"
        },
        "assumptions": {
          "anyOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "limitations": {
          "anyOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "decision_basis": {
          "type": "string"
        },
        "review_notes": {
          "type": "string"
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "optional": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha256"]
        },
        "manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "additionalProperties": true,
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "evaluations": {
      "additionalProperties": true
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactEntry"
      }
    },
    "provenance": {
      "anyOf": [
        { "$ref": "#/$defs/refObject" },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "refObject": {
      "type": "object",
      "required": ["$ref"],
      "additionalProperties": true,
      "properties": {
        "$ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "party": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      }
    },
    "fileEntry": {
      "type": "object",
      "required": ["path", "format"],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "record_count": {
          "type": "integer",
          "minimum": 0
        },
        "record_type_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "facet_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "artifactEntry": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
