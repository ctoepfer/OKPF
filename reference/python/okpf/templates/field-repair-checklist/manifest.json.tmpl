{
  "$comment": "SPDX-License-Identifier: Apache-2.0 | Copyright 2026 OKPF Contributors",
  "okpf_version": "0.1.0",
  "package_id": "{{ package_id }}",
  "name": "{{ name }}",
  "version": "{{ version }}",
  "domain": "{{ domain }}",
  "description": "Field repair checklist pack generated by `okpf init --template field-repair-checklist`.",
  "language": "en",
  "tags": ["checklist", "field-service"],
  "creators": [
    {
      "name": "{{ creator_name }}",
      "role": "author"
    }
  ],
  "license": {
    "type": "{{ license_type }}"
  },
  "usage_policy": {
    "allow_rag": true,
    "allow_evaluation": true,
    "require_attribution": true
  },
  "artifacts": [
    {
      "path": "artifacts/checklist.md",
      "type": "text/markdown",
      "role": "guide",
      "title": "Repair Checklist"
    }
  ],
  "records": [
    {
      "path": "records/checklist-items.jsonl",
      "format": "jsonl",
      "description": "Individual checklist steps as OKPF records."
    }
  ]
}
