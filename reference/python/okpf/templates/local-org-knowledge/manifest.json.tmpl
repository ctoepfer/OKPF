{
  "$comment": "SPDX-License-Identifier: Apache-2.0 | Copyright 2026 OKPF Contributors",
  "okpf_version": "0.1.0",
  "package_id": "{{ package_id }}",
  "name": "{{ name }}",
  "version": "{{ version }}",
  "domain": "{{ domain }}",
  "description": "Internal knowledge pack generated by `okpf init --template local-org-knowledge`.",
  "language": "en",
  "tags": ["internal", "policy"],
  "creators": [
    {
      "name": "{{ creator_name }}",
      "role": "author"
    }
  ],
  "license": {
    "type": "{{ license_type }}",
    "details": "Internal use only unless otherwise stated."
  },
  "usage_policy": {
    "allow_rag": true,
    "allow_evaluation": true,
    "allow_commercial_use": false,
    "require_attribution": true,
    "notes": "Internal organizational knowledge. Review before external sharing."
  },
  "artifacts": [
    {
      "path": "artifacts/policy.md",
      "type": "text/markdown",
      "role": "guide",
      "title": "Policy or Process Overview"
    }
  ],
  "records": [
    {
      "path": "records/knowledge.jsonl",
      "format": "jsonl",
      "description": "Structured internal knowledge as OKPF records."
    }
  ]
}
