{
  "$comment": "SPDX-License-Identifier: Apache-2.0 | Copyright 2026 OKPF Contributors",
  "okpf_version": "0.1.0",
  "package_id": "{{ package_id }}",
  "name": "{{ name }}",
  "version": "{{ version }}",
  "domain": "{{ domain }}",
  "description": "RAG-source pack generated by `okpf init --template rag-source`.",
  "language": "en",
  "tags": ["rag"],
  "creators": [
    {
      "name": "{{ creator_name }}",
      "role": "author"
    }
  ],
  "license": {
    "type": "{{ license_type }}"
  },
  "usage_policy": {
    "allow_rag": true,
    "allow_evaluation": true,
    "require_attribution": true
  },
  "artifacts": [
    {
      "path": "artifacts/source.md",
      "type": "text/markdown",
      "role": "source",
      "title": "Source Document"
    }
  ],
  "records": [
    {
      "path": "records/chunks.jsonl",
      "format": "jsonl",
      "description": "Pre-chunked records derived from artifacts/source.md."
    }
  ]
}
