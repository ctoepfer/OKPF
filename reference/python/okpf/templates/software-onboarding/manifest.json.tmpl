{
  "$comment": "SPDX-License-Identifier: Apache-2.0 | Copyright 2026 OKPF Contributors",
  "okpf_version": "0.1.0",
  "package_id": "{{ package_id }}",
  "name": "{{ name }}",
  "version": "{{ version }}",
  "domain": "{{ domain }}",
  "description": "Onboarding pack generated by `okpf init --template software-onboarding`.",
  "language": "en",
  "tags": ["onboarding", "engineering"],
  "creators": [
    {
      "name": "{{ creator_name }}",
      "role": "author"
    }
  ],
  "license": {
    "type": "{{ license_type }}"
  },
  "usage_policy": {
    "allow_rag": true,
    "allow_evaluation": true,
    "require_attribution": true
  },
  "artifacts": [
    {
      "path": "artifacts/setup.md",
      "type": "text/markdown",
      "role": "guide",
      "title": "Local Development Setup"
    },
    {
      "path": "artifacts/architecture.md",
      "type": "text/markdown",
      "role": "guide",
      "title": "Architecture Overview"
    },
    {
      "path": "artifacts/troubleshooting.md",
      "type": "text/markdown",
      "role": "guide",
      "title": "Troubleshooting"
    }
  ],
  "records": [
    {
      "path": "records/decisions.jsonl",
      "format": "jsonl",
      "description": "Architecture decisions as OKPF records."
    }
  ],
  "provenance": {
    "sources": "provenance/sources.json"
  },
  "evals": [
    {
      "path": "evals/onboarding-questions.json",
      "format": "json",
      "description": "Evaluation questions for onboarding knowledge verification."
    }
  ]
}
