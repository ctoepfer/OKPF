{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okpf.org/schemas/0.1/import_report.schema.json",
  "title": "OKPF v0.1 Import Report",
  "type": "object",
  "required": [
    "status",
    "items"
  ],
  "additionalProperties": true,
  "properties": {
    "import_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial_success",
        "failed"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "stage",
          "status",
          "message"
        ],
        "additionalProperties": true,
        "properties": {
          "path": {
            "type": "string"
          },
          "stage": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "warning",
              "error",
              "skipped"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
