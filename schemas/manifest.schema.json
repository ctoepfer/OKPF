{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okpf.org/schemas/0.1/manifest.schema.json",
  "title": "OKPF v0.1 Manifest",
  "type": "object",
  "required": [
    "okpf_version",
    "package_id",
    "name",
    "version",
    "domain",
    "profiles",
    "records"
  ],
  "additionalProperties": true,
  "properties": {
    "okpf_version": {
      "type": "string",
      "pattern": "^0\\.1(?:\\.0)?$"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileEntry"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileEntry"
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "fileEntry": {
      "type": "object",
      "required": [
        "path",
        "format"
      ],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "record_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
