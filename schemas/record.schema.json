{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okpf.org/schemas/0.1/record.schema.json",
  "title": "OKPF v0.1 Universal Record",
  "type": "object",
  "required": [
    "id",
    "record_type",
    "title",
    "text",
    "domain",
    "metadata"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "record_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
