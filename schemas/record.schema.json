{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okpf.org/schemas/0.1/record.schema.json",
  "title": "OKPF v0.1 Universal Record",
  "type": "object",
  "required": [
    "id",
    "record_type",
    "title",
    "text",
    "domain",
    "metadata"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "record_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "facets": {
      "type": "object",
      "description": "Optional machine-readable classification hints. OKPF Core does not define a global facet vocabulary.",
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" },
          {
            "type": "array",
            "items": {
              "anyOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            }
          },
          { "type": "object" },
          { "type": "null" }
        ]
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
